      "name": "Get-Usuario por ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code es 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"El campo id existe y es 1\", function() {",
              "    const data = pm.response.json();",
              "    pm.expect(data.id).to.equal(1);",
              "});",
              "",
              "pm.test(\"El campo email tiene formato válido\", function() {",
              "    const data = pm.response.json();",
              "    pm.expect(data.email).to.include(\"@\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
